{
  "expo": {
    "name": "HERO",
    "slug": "hero-game",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0d0d0d"
    },
    "scheme": "hero",
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.hero.game"
    },
    "android": {
      "package": "com.hero.game",
      "adaptiveIcon": {
        "backgroundColor": "#0d0d0d",
        "foregroundImage": "./assets/android-icon-foreground.png"
      }
    },
    "plugins": [
      "expo-router",
      "expo-image",
      "expo-secure-store",
      "expo-font",
      "expo-av"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "web": {
      "bundler": "metro"
    }
  }
}
